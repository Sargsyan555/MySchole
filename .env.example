# School site — copy to `.env` in this folder (next to package.json)

# --- Frontend (Vite; optional) ---
# Vercel / static hosting has no Express. Deploy `server/` elsewhere, then set this in Vercel
# Project Settings → Environment Variables (also at build time for `import.meta.env`):
# VITE_API_ORIGIN=https://your-express-host.example.com
# You must enable CORS + credentials on the API if the origin differs from the frontend.

# --- Backend (Express; use on the machine that runs `server/`, not only on Vercel) ---

# Admin login (required email match)
ADMIN_EMAIL=admin@school.local

# Signing key for httpOnly session cookie (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Recommended: bcrypt hash of your password (never commit real .env)
# Run: node server/scripts/hash-password.mjs "your-password"
# ADMIN_PASSWORD_HASH=$2b$10$...

# If ADMIN_PASSWORD_HASH is unset, this plain password is used (development only)
ADMIN_PASSWORD=admin
